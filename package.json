{
  "name": "tomate-cli",
  "version": "0.2.0",
  "description": "A robust Pomodoro CLI timer — TUI built with Ink/React",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "tomate": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/assets/**/*.{mp3,wav}\" dist",
    "start": "node ./dist/main.js",
    "clean": "rm -rf dist",
    "dev": "npm run clean && npm run build && npm run start",
    "reset-config": "node ./dist/main.js --reset-config",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "bundle": "npm run build && npx ncc build dist/main.js -o bundle",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "pomodoro",
    "typescript",
    "ink",
    "tui"
  ],
  "author": "Pierre Feilles <pierre.feilles@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.8",
    "copyfiles": "^2.4.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.4.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-cursor": "^5.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "figlet": "^1.11.0",
    "ink": "^5.1.0",
    "ink-big-text": "^2.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zod": "^3.24.3"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
